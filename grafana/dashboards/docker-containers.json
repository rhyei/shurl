{
  "title": "Docker Containers",
  "tags": [],
  "editable": true,
  "cursorSync": "Crosshair",
  "liveNow": false,
  "preload": false,
  "schemaVersion": 39,
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "refresh": "5s",
  "annotations": {
    "list": [
      {
        "builtIn": true,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "container",
        "label": "Container",
        "datasource": {
          "type": "prometheus"
        },
        "definition": "label_values(container_memory_working_set_bytes, name)",
        "query": "label_values(container_memory_working_set_bytes, name)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 9,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "title": "CPU Usage by Container",
      "description": "CPU usage is shown in cores, not percent",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },
          "editorMode": "code",
          "exemplar": true,
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"${container:regex}\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "{{name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "sortBy": "Last",
          "sortDesc": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        }
      }
    },
    {
      "id": 10,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
