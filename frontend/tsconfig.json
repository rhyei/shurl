{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "composite": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "#/api": ["./generated/api/index.ts"],
      "#/*": ["./src/*"]
    },
    "types": ["vite/client", "bun"],
    "strict": true
  },
  "include": [
    "src/**/*",
    "generated/**/*",
    "heyapi.config.ts",
    "oxfmt.config.ts",
    "vite.config.ts",
    "../oxfmt.config.ts"
  ]
}
