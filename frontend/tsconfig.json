{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "composite": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "#/api": ["./generated/api/index.ts"],
      "#/api/tanstack": ["./generated/api/@tanstack/react-query.gen.ts"],
      "#/api/client": ["./generated/api/client.gen"],
      "#/*": ["./src/*"]
    },
    "types": ["vite/client", "bun"],
    "strict": true
  },
  "include": [
    "./src/**/*",
    "./generated/**/*",
    "./heyapi.config.ts",
    "./oxfmt.config.ts",
    "./vite.config.ts",
    "./env.d.ts",
    "../oxfmt.config.ts"
  ]
}
